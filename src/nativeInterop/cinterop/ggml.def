// cinterop definition for platform-level C primitives.
// This provides access to kotlinx.cinterop types (CPointer, ByteVar,
// nativeHeap, etc.) needed for faithful C++ transliteration.
// The ggml headers give us the C struct layouts and type definitions
// that the ported Kotlin code mirrors.

headers = ggml.h gguf.h ggml-backend.h ggml-cpu.h ggml-alloc.h
headerFilter = ggml.h gguf.h ggml-backend.h ggml-cpu.h ggml-alloc.h

compilerOpts = -I../tmp/llama.cpp/ggml/include
